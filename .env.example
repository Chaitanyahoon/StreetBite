# ============================================================================
# StreetBite Environment Variables (Development)
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git (it's in .gitignore)

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Firebase Service Account Credentials
# Get from: https://console.firebase.google.com/ → Settings → Service Accounts
# Generate New Private Key → Save as firebase-key.json in project root
GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json

# Google Maps Geocoding API Key
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Create API Key → Enable Geocoding API
GOOGLE_GEOCODING_API_KEY=your-google-maps-api-key-here

# Backend Server Configuration
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# Local MySQL Development Defaults
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/streetbite?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root
SPRING_SQL_INIT_MODE=always
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
STREETBITE_ALLOW_INSECURE_DEFAULTS=true
STREETBITE_SEED_ENABLED=true

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Backend URL (used by Next.js to call API)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8081/api

# Firebase Client Config (already set in code, but can override here)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================================================
# OPTIONAL / PRODUCTION ONLY
# ============================================================================

# JWT Secret (for authentication)
# Change this in production to a strong random string
JWT_SECRET=dev-secret-change-in-production

# Database Connection (if not using Firebase)
# DATABASE_URL=jdbc:postgresql://localhost:5432/streetbite

# Email Service (for notifications)
# MAIL_SERVICE_API_KEY=your-mail-service-key

# Cloud Storage (for image uploads)
# CLOUD_STORAGE_BUCKET=streetbite-images
