# Server
SERVER_PORT=8081

# Database: MySQL is the source of truth
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/streetbite?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true

# Auth
JWT_SECRET=replace_with_a_random_32_plus_char_secret
JWT_EXPIRATION_MS=86400000

# Frontend / CORS / Cookies
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000
APP_ENV=development
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# Optional: Google Geocoding
GOOGLE_GEOCODING_API_KEY=

# Optional: Firebase Admin
# Used only for realtime mirrors and push notifications.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json

# Optional: SMTP mail
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_CONNECTION_TIMEOUT=10000
SPRING_MAIL_SMTP_TIMEOUT=10000
SPRING_MAIL_SMTP_WRITE_TIMEOUT=10000
SPRING_MAIL_SMTP_SSL_TRUST=
